ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=healthmate;Username=healthmate;Password=changeme
Jwt__Key=
Jwt__Issuer=HealthMate_Servers
Jwt__Audience=HealthMate_Clients
Gemini__ApiKey=
Gemini__BaseUrl=https://generativelanguage.googleapis.com/v1beta/
EmailSettings__Email=
EmailSettings__Password=
Cors__AllowedOrigins__0=http://localhost:4200
POSTGRES_USER=healthmate
POSTGRES_PASSWORD=changeme
POSTGRES_DB=healthmate

# --- ML sidecar ---
# ML_AUTH_TOKEN is consumed by the Python service to verify bearer tokens.
# MlService__AuthToken is the matching value used by the .NET HttpClient.
# Keep them identical; the duplication exists because each side reads from its
# own configuration system (env var vs. ASP.NET Configuration).
ML_AUTH_TOKEN=changeme-rotate-me
MlService__BaseUrl=http://ml:8000
MlService__AuthToken=changeme-rotate-me

# --- Sina clinical assistant ---
# Provider picks which LLM adapter Sina uses. One of: Gemini | OpenAi.
# Only the selected provider's API key is required.
Sina__Provider=Gemini
Sina__MaxToolCallsPerTurn=8
Sina__Gemini__ApiKey=
Sina__Gemini__BaseUrl=https://generativelanguage.googleapis.com/v1beta/
Sina__Gemini__Model=gemini-1.5-pro
Sina__OpenAi__ApiKey=
Sina__OpenAi__BaseUrl=https://api.openai.com
Sina__OpenAi__Model=gpt-4o-mini
